<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Pa2" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorAccent">@color/teal</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/teal_dark</item>
    </style>

    <style name="MetricLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">13sp</item>
        <item name="android:paddingTop">4dp</item>
    </style>

    <style name="MetricValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingBottom">6dp</item>
    </style>
</resources>
